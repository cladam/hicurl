@project {
    name: "hicurl"
    version: "0.1.0"
    license: "MIT"
    entry: "src/main.hc"
}

@dependencies {
    json: "latest"
    http: "latest"
}

@koka {
    flags: "--cclib=curl --ccincdir=/opt/homebrew/include --cclinkopts=-L/opt/homebrew/lib"
}

@description {
    summary: "hicurl - a modern HTTP CLI"
    author: "cladam"
    homepage: "https://www.hica.dev"
    repository: "https://github.com/cladam/hicurl.git"
}
